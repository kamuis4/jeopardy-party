# ─────────────────────────────────────────────────────────────
#  JEOPARDY PARTY — Backend Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values

# Port the server listens on (Render/Railway set this automatically)
PORT=3001

# URL of your deployed frontend (Vercel/Netlify URL)
# Use * to allow all origins during development
FRONTEND_URL=http://localhost:5500

# Optional: MongoDB Atlas connection string
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/jeopardy

# Optional: Supabase
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-anon-key
