# ─────────────────────────────────────────────────────────────
#  JEOPARDY PARTY — Variables d'environnement
#  Copie ce fichier en .env et remplis tes valeurs
# ─────────────────────────────────────────────────────────────

# Port du serveur (Render/Railway le définit automatiquement)
PORT=3001

# URL du frontend déployé (Vercel/Netlify)
# En dev local, utilise * pour tout autoriser
FRONTEND_URL=http://localhost:5500

# ── MongoDB Atlas ─────────────────────────────────────────────
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Laisse vide pour utiliser le fallback local (packs.js)
MONGODB_URI=mongodb+srv://kamuis:kamuisDB@cluster0.suusbpg.mongodb.net/?appName=Cluster0
